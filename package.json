{
  "name": "dentist4-website",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "optimize:assets": "node scripts/optimize-assets.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "test": "node --test tests/site-contracts.test.mjs",
    "deploy:preview": "wrangler pages deploy dist --project-name dentist4-website --branch preview",
    "deploy:production": "wrangler pages deploy dist --project-name dentist4-website --branch master"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.3.3",
    "astro": "7.1.3",
    "tailwindcss": "4.3.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "typescript": "6.0.3",
    "wrangler": "4.113.0"
  },
  "overrides": {
    "sharp": "0.35.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.35.3": true,
    "workerd@1.20260721.1": true
  }
}
