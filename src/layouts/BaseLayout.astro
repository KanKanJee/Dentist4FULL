---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  indexable?: boolean;
}

const { title, description, canonicalPath = '/', indexable = true } = Astro.props;
const canonical = new URL(canonicalPath, Astro.site);
const socialImage = new URL('/img/ododiatros-theodoros-kouimtzis-sto-iatrio.jpg', Astro.site);
---

<!doctype html>
<html lang="el">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content={indexable ? 'index, follow' : 'noindex, nofollow'} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/img/favicon.ico" sizes="48x48" />
    <link rel="preload" href="/fonts/manrope-greek.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/roboto-greek.woff2" as="font" type="font/woff2" crossorigin />
    {canonicalPath === '/' && (
      <>
        <link
          rel="preload"
          as="image"
          type="image/avif"
          href="/img/performance/hero-mobile-768.avif"
          imagesrcset="/img/performance/hero-mobile-640.avif 640w, /img/performance/hero-mobile-768.avif 768w, /img/performance/hero-mobile-960.avif 960w"
          imagesizes="100vw"
          media="(max-width: 639px)"
          fetchpriority="high"
        />
        <link
          rel="preload"
          as="image"
          type="image/avif"
          href="/img/performance/hero-desktop-1920.avif"
          imagesrcset="/img/performance/hero-desktop-1280.avif 1280w, /img/performance/hero-desktop-1920.avif 1920w, /img/performance/hero-desktop-2560.avif 2560w"
          imagesizes="100vw"
          media="(min-width: 640px)"
          fetchpriority="high"
        />
      </>
    )}
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="//cdn-cookieyes.com" />
    <meta property="og:locale" content="el_GR" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Παιδοδοντίατρος Θεόδωρος Κουιμτζής Νέα Σμύρνη / Αθήνα" />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Παιδοδοντίατρος Θεόδωρος Κουιμτζής Νέα Σμύρνη / Αθήνα" />
    <meta property="og:image" content={socialImage} />
    <script is:inline>
      if (location.hostname === 'dentistforchildren.gr' || location.hostname === 'www.dentistforchildren.gr') {
        window.dataLayer = window.dataLayer || [];

        const loadGtm = () => {
          if (window.__dentistGtmLoaded) return;
          window.__dentistGtmLoaded = true;
          window.dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });

          const firstScript = document.getElementsByTagName('script')[0];
          const gtmScript = document.createElement('script');
          gtmScript.async = true;
          gtmScript.src = 'https://www.googletagmanager.com/gtm.js?id=GTM-N8VQXBC';
          firstScript.parentNode.insertBefore(gtmScript, firstScript);
        };

        const scheduleGtm = () => {
          if ('requestIdleCallback' in window) {
            window.requestIdleCallback(loadGtm, { timeout: 1200 });
          } else {
            window.setTimeout(loadGtm, 0);
          }
        };

        window.addEventListener('load', scheduleGtm, { once: true });
        window.addEventListener('pointerdown', loadGtm, { once: true, passive: true });
        window.addEventListener('touchstart', loadGtm, { once: true, passive: true });
        window.addEventListener('keydown', loadGtm, { once: true });
      }
    </script>
  </head>
  <body>
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-N8VQXBC" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:rounded-full focus:bg-white focus:px-5 focus:py-3">Μετάβαση στο περιεχόμενο</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <BackToTop />
    <Footer />
  </body>
</html>
