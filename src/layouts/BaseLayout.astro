---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import CookieConsent from '../components/CookieConsent.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  indexable?: boolean;
}

const { title, description, canonicalPath = '/', indexable = true } = Astro.props;
const canonical = new URL(canonicalPath, Astro.site);
const socialImage = new URL('/img/ododiatros-theodoros-kouimtzis-sto-iatrio.jpg', Astro.site);
---

<!doctype html>
<html lang="el">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content={indexable ? 'index, follow' : 'noindex, nofollow'} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/img/favicon.ico" sizes="48x48" />
    <link rel="preload" href="/fonts/manrope-site-v1.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/roboto-site-v1.woff2" as="font" type="font/woff2" crossorigin />
    {canonicalPath === '/' && (
      <>
        <link
          rel="preload"
          as="image"
          type="image/avif"
          href="/img/performance/hero-mobile-768-v2.avif"
          imagesrcset="/img/performance/hero-mobile-640-v2.avif 640w, /img/performance/hero-mobile-768-v2.avif 768w, /img/performance/hero-mobile-960-v2.avif 960w"
          imagesizes="100vw"
          media="(max-width: 639px)"
          fetchpriority="high"
        />
        <link
          rel="preload"
          as="image"
          type="image/avif"
          href="/img/performance/hero-desktop-1920-v2.avif"
          imagesrcset="/img/performance/hero-desktop-1280-v2.avif 1280w, /img/performance/hero-desktop-1920-v2.avif 1920w, /img/performance/hero-desktop-2560-v2.avif 2560w"
          imagesizes="100vw"
          media="(min-width: 640px)"
          fetchpriority="high"
        />
      </>
    )}
    <meta property="og:locale" content="el_GR" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Παιδοδοντίατρος Θεόδωρος Κουιμτζής Νέα Σμύρνη / Αθήνα" />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Παιδοδοντίατρος Θεόδωρος Κουιμτζής Νέα Σμύρνη / Αθήνα" />
    <meta property="og:image" content={socialImage} />
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      const readCookie = (name) => {
        const prefix = `${name}=`;
        const entry = document.cookie.split('; ').find((cookie) => cookie.startsWith(prefix));
        return entry ? decodeURIComponent(entry.slice(prefix.length)) : '';
      };
      const storedConsent = readCookie('dentist_cookie_consent');
      const legacyConsent = readCookie('cookieyes-consent');
      const consent = {
        decided: storedConsent.startsWith('v1|') || /(?:^|,)action:yes(?:,|$)/.test(legacyConsent),
        analytics: /(?:^|\|)analytics:1(?:\||$)/.test(storedConsent) || /(?:^|,)analytics:yes(?:,|$)/.test(legacyConsent),
        advertising: /(?:^|\|)advertising:1(?:\||$)/.test(storedConsent) || /(?:^|,)advertisement:yes(?:,|$)/.test(legacyConsent),
      };
      window.__dentistConsent = consent;

      if (location.hostname === 'dentistforchildren.gr' || location.hostname === 'www.dentistforchildren.gr') {
        window.dataLayer.push({ 'gtm.blocklist': ['sandboxedScripts'] });
        window.gtag = function () {
          window.dataLayer.push(arguments);
        };
        window.gtag('consent', 'default', {
          ad_storage: consent.advertising ? 'granted' : 'denied',
          ad_user_data: consent.advertising ? 'granted' : 'denied',
          ad_personalization: consent.advertising ? 'granted' : 'denied',
          analytics_storage: consent.analytics ? 'granted' : 'denied',
          functionality_storage: 'granted',
          security_storage: 'granted',
        });
        window.gtag('set', 'ads_data_redaction', true);
        window.gtag('set', 'url_passthrough', true);

        const loadGtm = () => {
          if (window.__dentistGtmLoaded) return;
          window.__dentistGtmLoaded = true;
          window.dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });

          const firstScript = document.getElementsByTagName('script')[0];
          const gtmScript = document.createElement('script');
          gtmScript.async = true;
          gtmScript.src = 'https://www.googletagmanager.com/gtm.js?id=GTM-N8VQXBC';
          firstScript.parentNode.insertBefore(gtmScript, firstScript);
        };
        window.__loadDentistGtm = loadGtm;

        const scheduleGtm = () => {
          if ('requestIdleCallback' in window) {
            window.requestIdleCallback(loadGtm, { timeout: 1200 });
          } else {
            window.setTimeout(loadGtm, 0);
          }
        };

        if (consent.decided && (consent.analytics || consent.advertising)) {
          window.addEventListener('load', scheduleGtm, { once: true });
        }
      }
    </script>
  </head>
  <body>
    <Fragment set:html="<!--email_off-->" />
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:rounded-full focus:bg-white focus:px-5 focus:py-3">Μετάβαση στο περιεχόμενο</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <BackToTop />
    <CookieConsent />
    <Footer />
    <Fragment set:html="<!--/email_off-->" />
  </body>
</html>
