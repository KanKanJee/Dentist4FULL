---
const navLeft = [
  { href: '/paidododiatros', label: 'οδοντιατρος' },
  { href: '/iatrio', label: 'ιατρειο' },
  { href: '/ipiresies', label: 'υπηρεσιες' },
];
const navRight = [
  { href: '/epigoda', label: 'επειγοντα' },
  { href: '/sixnes-erotisis', label: 'ερωτησεις' },
  { href: '/epikinonia', label: 'επικοινωνια' },
];
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="sticky top-0 z-50 transform-gpu border-b border-ink/5 bg-cream/95 backdrop-blur-xl transition-transform duration-300 ease-out motion-reduce:transition-none will-change-transform" data-site-header>
  <nav class="section-shell flex h-20 items-center justify-between lg:grid lg:grid-cols-[1fr_auto_1fr]" aria-label="Κύρια πλοήγηση">
    <ul class="hidden items-center gap-8 lg:flex">
      {navLeft.map((item) => (
        <li>
          <a href={item.href} aria-current={path === item.href ? 'page' : undefined} class:list={['text-[0.72rem] font-bold uppercase tracking-[0.14em] transition hover:text-mint-deep', path === item.href ? 'text-mint-deep' : 'text-ink/75']}>{item.label}</a>
        </li>
      ))}
    </ul>

    <a href="/" class="flex items-center justify-center" aria-label="Αρχική">
      <img src="/img/SMILE.png" width="100" height="68" alt="logo" class="h-10 w-auto" />
    </a>

    <ul class="hidden items-center justify-end gap-8 lg:flex">
      {navRight.map((item) => (
        <li>
          <a href={item.href} aria-current={path === item.href ? 'page' : undefined} class:list={['text-[0.72rem] font-bold uppercase tracking-[0.14em] transition hover:text-mint-deep', path === item.href ? 'text-mint-deep' : 'text-ink/75']}>{item.label}</a>
        </li>
      ))}
    </ul>

    <button type="button" class="grid size-11 place-items-center rounded-full border border-ink/10 lg:hidden" aria-expanded="false" aria-controls="mobile-menu" data-menu-toggle>
      <span class="sr-only">Άνοιγμα μενού</span>
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16" /></svg>
    </button>
  </nav>

  <div id="mobile-menu" class="fixed inset-x-0 top-20 hidden h-[calc(100dvh-5rem)] border-t border-ink/5 bg-cream px-5 py-8 lg:hidden" data-mobile-menu>
    <ul class="grid gap-2">
      {[...navLeft, ...navRight].map((item) => (
        <li><a href={item.href} class="flex items-center justify-between rounded-2xl border border-ink/5 bg-white px-5 py-4 text-sm font-bold uppercase tracking-[0.13em] text-ink"><span>{item.label}</span><span aria-hidden="true">↗</span></a></li>
      ))}
    </ul>
    <a href="tel:2109354588" class="button-primary mt-8 w-full">210 9354588</a>
  </div>
</header>

<script>
  const header = document.querySelector('[data-site-header]');
  const toggle = document.querySelector('[data-menu-toggle]');
  const menu = document.querySelector('[data-mobile-menu]');

  const revealHeader = () => header?.classList.remove('-translate-y-full');

  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    menu?.classList.toggle('hidden', open);
    document.body.classList.toggle('menu-open', !open);
    if (!open) revealHeader();
  });

  let lastScrollY = 0;
  let ticking = false;

  const updateHeader = () => {
    const currentScrollY = Math.max(window.scrollY, 0);
    const scrollDelta = currentScrollY - lastScrollY;
    const menuOpen = toggle?.getAttribute('aria-expanded') === 'true';

    if (menuOpen || currentScrollY <= 80) {
      revealHeader();
    } else if (Math.abs(scrollDelta) >= 4) {
      header?.classList.toggle('-translate-y-full', scrollDelta > 0);
    }

    if (Math.abs(scrollDelta) >= 4 || currentScrollY <= 80) {
      lastScrollY = currentScrollY;
    }
    ticking = false;
  };

  window.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(updateHeader);
      ticking = true;
    }
  }, { passive: true });

  header?.addEventListener('focusin', revealHeader);
</script>
