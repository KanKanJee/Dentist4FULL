---
interface Props {
  image: string;
  alt?: string;
  title: string;
  reverse?: boolean;
}
const { image, alt = '', title, reverse = false } = Astro.props;
---

<section class="bg-white">
  <div class="grid min-h-[34rem] lg:grid-cols-2">
    <div class:list={['relative min-h-[24rem] overflow-hidden lg:min-h-full', reverse && 'lg:order-2']}>
      <img src={image} alt={alt} class="absolute inset-0 size-full object-cover transition duration-700 hover:scale-[1.02]" loading="lazy" />
    </div>
    <div class:list={['flex items-center px-6 py-16 sm:px-12 lg:px-[12%] lg:py-24', reverse && 'lg:order-1']}>
      <div class="max-w-xl">
        <h2 class="section-title">{title}</h2>
        <div class="body-copy mt-7"><slot /></div>
      </div>
    </div>
  </div>
</section>
